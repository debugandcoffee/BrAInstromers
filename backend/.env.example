OPENAI_API_KEY=

# Optional, required only for EPO OPS ingestion.
OPS_CONSUMER_KEY=
OPS_CONSUMER_SECRET=

# SQLite document cache used by ingestion and the future retriever.
DOCUMENT_DB_PATH=data/documents.sqlite3
SCHEDULER_JOBS_PATH=scheduler_jobs.json
SCHEDULER_STATE_PATH=data/scheduler_state.json

# EU Funding & Tenders Portal has public portal API pages, but concrete endpoints
# may change. Override this when you confirm the endpoint from the portal support page.
EU_FUNDING_API_URL=https://api.tech.ec.europa.eu/search-api/prod/rest/search
EMBEDDING_MODEL=intfloat/multilingual-e5-small
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
